procedure Tdm_bpr1.RvSystem1AfterPrint(Sender: TObject);
begin
  UpdateUserLog('Cetak Report ',True,RvOgisoft.ReportName+','+RvOgisoft.ReportDesc);
end;

procedure Tdm_bpr1.RvSystem1BeforePrint(Sender: TObject);
begin
  if MyQLogo.Active then
    MyQLogo.Refresh
  else
    MyQLogo.Open;

    //RvOgisoft.SetParam('cTglIndo',DateIndo(Now));
    RvOgisoft.SetParam('cNamaUser',UpperCase(cNamaUser));
    RvOgisoft.SetParam('NamaPT',cNamaPT);
    RvOgisoft.SetParam('AlamatPT1',cAlamatPT+', '+cKotaPT+', '+cTelpPT);
    RvOgisoft.SetParam('cKota',cKotaPT);
    RvOgisoft.SetParam('cTglIndo',DateIndo(dTglSystem));
    RvOgisoft.SetParam('cFooter',UpperCase(cNamaUser)+', '+DateIndo(dTglSystem)+' '+TimeToStr(Now));
    RvOgisoft.SetParam('cEnter',Chr(13)+Chr(10));
    
end;

