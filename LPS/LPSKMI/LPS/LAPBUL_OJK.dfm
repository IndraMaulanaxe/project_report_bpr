  object MyQuery1: TMyQuery
    Connection = dm_bpr1.MyCon2
    SQL.Strings = (
      
        'SELECT '#39'D'#39' AS `flag_detail`, ns.nasabah_id AS `cif`, '#39'1'#39' AS `jen' +
        'is_identitas`, '
      
        '    '#39'123'#39' AS `nik_passport`, nama_nasabah AS `nama`, nama_nasaba' +
        'h_sid AS `nama_lengkap`, '
      '    #`kode_status_gelar`, '
      
        '    IF(jenis_kelamin='#39'L'#39','#39'P'#39','#39'W'#39') AS `jenis_kelamin`, `tempatlah' +
        'ir` AS `tempat_lahir`, `tgllahir` AS `tanggal_lahir`, '
      
        '    IF(npwp='#39'12.345.678.9.123.456'#39','#39#39',REPLACE(npwp,'#39'.'#39','#39#39')) AS `' +
        'npwp`, `ktp_alamat` AS `alamat`, `ktp_desa` AS `kelurahan`, '
      
        '    `ktp_kecamatan` AS `kecamatan`, `ktp_kota_kab` AS `kode_kab_' +
        'kota`, `ktp_kodepos` AS `kode_pos`, '
      
        '    `telpon` AS `telepon`, `hp` AS `no_hp`, email AS `alamat_ema' +
        'il`, '#39'ID'#39' AS `kode_negara`,'
      '    `jenis_debitur`'
      
        '    #`kode_pekerjaan`, `tempat_bekerja`, `kode_bidang_usaha`, `a' +
        'lamat_perkerjaan`, `penghasilan_kotor`, `kode_sumber_penghasilan' +
        '`, `jumlah_tanggungan`, `kode_hub_ljk`, `kode_golongan_debitur`,' +
        ' `status_perkawinan`, `nik_passport_pasangan`, `nama_pasangan`, ' +
        '`tanggal_lahir_pasangan`, `perjanjian_pisah_harta`, `melanggar_b' +
        'mpk`, `melampaui_bmpk`, `nama_gadis_ibu_kandung`, `kode_kantor_c' +
        'abang`, `operasi_data`'
      'FROM `nasabah` ns'
      
        '  LEFT JOIN `nasabah_alamat` na ON na.`nasabah_id`=ns.`nasabah_i' +
        'd`'
      'WHERE na.`ktp_alamat` IS NOT NULL')
    Left = 632
    Top = 112
  end
